DATABASE_URL=postgresql+psycopg://graphrag:graphrag@localhost:5432/graphrag
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphrag-demo
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=graphrag
MINIO_SECRET_KEY=graphrag-demo
MINIO_BUCKET=graphrag-documents
MINIO_SECURE=false
EXTRACTION_SERVICE_URL=http://localhost:8001/extract

# Yandex AI Studio: извлечение фактов и эмбеддинги (использует docker-compose.override.yml).
# Без ключа стек поднимется, но извлечение будет отвечать явной ошибкой
# авторизации (документы получат статус failed). Для автономного mock-режима
# переименуйте docker-compose.override.yml — извлечение уйдёт на ml-mock.
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# Запасной OpenAI-совместимый LLM для query-вызовов (например, Ollama:
# http://host.docker.internal:11434/v1). Пустой FALLBACK_BASE_URL — ступень отключена.
FALLBACK_BASE_URL=
FALLBACK_MODEL=
# Ключ запасного сервера; локальному Ollama не нужен — оставить пустым
FALLBACK_API_KEY=
