{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Scientific experiment claim candidate",
  "type": "object",
  "required": [
    "material",
    "experiment_id",
    "sample",
    "process",
    "property",
    "effect_direction",
    "lab",
    "team"
  ],
  "properties": {
    "material": { "type": "string" },
    "experiment_id": { "type": "string" },
    "sample": { "type": "string" },
    "process": { "type": "string" },
    "temperature_c": { "type": ["number", "null"] },
    "duration_h": { "type": ["number", "null"] },
    "property": { "type": "string" },
    "effect_direction": {
      "type": "string",
      "enum": ["increase", "decrease", "neutral", "unknown"]
    },
    "effect_value": { "type": ["number", "null"] },
    "effect_unit": { "type": ["string", "null"] },
    "result_value": { "type": ["number", "null"] },
    "result_unit": { "type": ["string", "null"] },
    "lab": { "type": "string" },
    "team": { "type": "string" },
    "equipment": { "type": ["string", "null"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "additionalProperties": true
}

